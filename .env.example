BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789

# Для Docker DB_HOST переопределяется в docker-compose.yml на "mysql"
DB_HOST=localhost
DB_PORT=3306
DB_NAME=laptop_tracker
DB_USER=root
# Локально: часто пустой пароль у root. На сервере (Docker): laptop_secret
DB_PASSWORD=

TZ=Asia/Tashkent

# Если сервер блокирует api.telegram.org (ETIMEDOUT), укажите прокси:
# TELEGRAM_PROXY=socks5://user:pass@host:port
# TELEGRAM_PROXY=http://user:pass@host:port
