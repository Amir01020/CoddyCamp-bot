{
  "name": "laptop-tracker-bot",
  "version": "1.0.0",
  "description": "Telegram-бот учёта выдачи и возврата ноутбуков",
  "main": "src/bot/index.js",
  "scripts": {
    "start": "node src/bot/index.js",
    "bot": "node src/bot/index.js",
    "db:create": "sequelize-cli db:create",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f bot",
    "docker:restart": "docker compose restart bot",
    "server": "node server.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "mysql2": "^3.12.0",
    "sequelize": "^6.37.5",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "sequelize-cli": "^6.6.2"
  }
}
